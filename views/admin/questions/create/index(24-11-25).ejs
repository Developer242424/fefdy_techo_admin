      <script>
        window.onload = () => {
          const imgBtn = document.getElementById('imgBtn');
          imgBtn.onclick = () => {
            alert("test");
          };
        };

        $(function () {
          let selectedElement = null;
          let isDragging = false;
          let dragOffsetX = 0;
          let dragOffsetY = 0;
          let dropzoneMap = {};

          const imgBtn = document.getElementById('imgBtn');
          const imgInput = document.getElementById('imgInput');
          const previewImg = document.getElementById('previewImg');
          const dropzoneBtn = document.getElementById('dropzoneBtn');
          const lineBtn = document.getElementById('lineBtn');
          const questionText = document.getElementById('questionText');
          const imageBox = document.getElementById('imageBox');
          const answerBox = document.getElementById('answerBox');
          const deleteBtn = document.getElementById('deleteBtn');

          const styleWidth = document.getElementById('styleWidth');
          const styleHeight = document.getElementById('styleHeight');
          const styleColor = document.getElementById('styleColor');
          const styleBorder = document.getElementById('styleBorder');
          const styleThickness = document.getElementById('styleThickness');
          const borderField = document.getElementById('borderField');
          const thicknessField = document.getElementById('thicknessField');

          const dropzoneFields = document.getElementById('dropzoneFields');
          const valueFields = document.getElementById('valueFields');
          const dropzoneName = document.getElementById('dropzoneName');
          const dropzoneValue = document.getElementById('dropzoneValue');
          const nameError = document.getElementById('nameError');

          // IMAGE UPLOAD
          // imgBtn.onclick = () => imgInput.click();
          imgBtn.onclick = () => {
            alert("test")
          }

          let uploadedImageName = '';

          imgInput.onchange = (e) => {
            const file = e.target.files[0];
            if (!file) return;

            uploadedImageName = prompt('Enter image filename:', file.name) || file.name;

            const reader = new FileReader();
            reader.onload = (event) => {
              previewImg.src = event.target.result;
              previewImg.style.display = 'block';
            };
            reader.readAsDataURL(file);
          };

          // CREATE DROP ZONE
          dropzoneBtn.onclick = () => {
            const dropzone = document.createElement('div');
            dropzone.className = 'dropzone';
            dropzone.style.left = '80px';
            dropzone.style.top = '50px';
            imageBox.appendChild(dropzone);

            attachElementHandlers(dropzone);
            selectElement(dropzone);
          };

          // CREATE LINE
          lineBtn.onclick = () => {
            const line = document.createElement('div');
            line.className = 'line';
            line.style.left = '80px';
            line.style.top = '50px';
            imageBox.appendChild(line);

            attachElementHandlers(line);
            selectElement(line);
          };

          // ATTACH DRAG & CLICK HANDLERS
          function attachElementHandlers(element) {
            element.onmousedown = (e) => {
              selectElement(element);
              startDrag(e, element);
            };
          }

          // SELECT ELEMENT
          function selectElement(element) {
            if (selectedElement) {
              selectedElement.classList.remove('selected');
            }

            selectedElement = element;
            element.classList.add('selected');

            // Load properties
            const isDropzone = element.classList.contains('dropzone');
            const isLine = element.classList.contains('line');

            styleWidth.value = element.style.width.replace('px', '') || (isDropzone ? 80 : 80);
            styleHeight.value = element.style.height.replace('px', '') || (isDropzone ? 40 : 2);
            styleColor.value = element.style.backgroundColor
              ? rgbToHex(element.style.backgroundColor)
              : (isDropzone ? '#ffffff' : '#000000');

            if (isDropzone) {
              borderField.style.display = 'block';
              thicknessField.style.display = 'none';
              dropzoneFields.classList.add('show');
              valueFields.classList.add('show');

              styleBorder.value = element.style.borderColor
                ? rgbToHex(element.style.borderColor)
                : '#000000';

              dropzoneName.value = element.dataset.zoneName || '';
              dropzoneValue.value = element.dataset.zoneValue || '';
              nameError.textContent = '';
              dropzoneName.classList.remove('error');
            } else if (isLine) {
              borderField.style.display = 'none';
              thicknessField.style.display = 'block';
              dropzoneFields.classList.remove('show');
              valueFields.classList.remove('show');
              styleThickness.value = element.style.height.replace('px', '') || 2;
            } else {
              dropzoneFields.classList.remove('show');
              valueFields.classList.remove('show');
              borderField.style.display = 'none';
              thicknessField.style.display = 'none';
            }
          }

          // START DRAG
          function startDrag(e, element) {
            isDragging = true;
            const rect = element.getBoundingClientRect();
            const parentRect = imageBox.getBoundingClientRect();

            dragOffsetX = e.clientX - rect.left;
            dragOffsetY = e.clientY - rect.top;

            document.onmousemove = (moveEvent) => {
              const newX = moveEvent.clientX - parentRect.left - dragOffsetX;
              const newY = moveEvent.clientY - parentRect.top - dragOffsetY;

              element.style.left = newX + 'px';
              element.style.top = newY + 'px';
            };

            document.onmouseup = () => {
              isDragging = false;
              document.onmousemove = null;
              document.onmouseup = null;
            };
          }

          // UPDATE STYLES
          styleWidth.oninput = () => {
            if (selectedElement) {
              selectedElement.style.width = styleWidth.value + 'px';
            }
          };

          styleHeight.oninput = () => {
            if (selectedElement) {
              selectedElement.style.height = styleHeight.value + 'px';
            }
          };

          styleColor.oninput = () => {
            if (selectedElement) {
              selectedElement.style.backgroundColor = styleColor.value;
            }
          };

          styleBorder.oninput = () => {
            if (selectedElement && selectedElement.classList.contains('dropzone')) {
              selectedElement.style.borderColor = styleBorder.value;
            }
          };

          styleThickness.oninput = () => {
            if (selectedElement && selectedElement.classList.contains('line')) {
              selectedElement.style.height = styleThickness.value + 'px';
            }
          };

          // DROPZONE NAME INPUT
          dropzoneName.oninput = () => {
            if (!selectedElement || !selectedElement.classList.contains('dropzone')) return;

            const newName = dropzoneName.value.trim();
            const oldName = selectedElement.dataset.zoneName;
            nameError.textContent = '';
            dropzoneName.classList.remove('error');

            if (newName && isDuplicateZoneName(newName, selectedElement)) {
              nameError.textContent = 'This ID already exists';
              dropzoneName.classList.add('error');
              return;
            }

            selectedElement.dataset.zoneName = newName;

            if (oldName && dropzoneMap[oldName]) {
              const answerElem = dropzoneMap[oldName];
              answerElem.dataset.elementId = newName;
              dropzoneMap[newName] = answerElem;
              delete dropzoneMap[oldName];
            }

          };

          // DROPZONE VALUE INPUT
          dropzoneValue.oninput = () => {
            if (!selectedElement || !selectedElement.classList.contains('dropzone')) return;

            const newValue = dropzoneValue.value.trim();
            selectedElement.dataset.zoneValue = newValue;

            if (dropzoneMap[selectedElement.dataset.zoneName]) {
              const answerElem = dropzoneMap[selectedElement.dataset.zoneName];
              answerElem.textContent = newValue;
            }


            // Create answer element if name and value both exist
            if (selectedElement.dataset.zoneName && newValue) {
              if (!dropzoneMap[selectedElement.dataset.zoneName]) {
                createAnswerElement(selectedElement);
              }
            }
          };

          // CHECK FOR DUPLICATE ZONE NAMES
          function isDuplicateZoneName(name, currentZone) {
            const allDropzones = imageBox.querySelectorAll('.dropzone');
            for (let zone of allDropzones) {
              if (zone !== currentZone && zone.dataset.zoneName === name) {
                return true;
              }
            }
            return false;
          }

          // CREATE ANSWER ELEMENT
          function createAnswerElement(dropzone) {
            const name = dropzone.dataset.zoneName;
            const value = dropzone.dataset.zoneValue;


            if (dropzoneMap[name]) return;

            const answerElem = document.createElement('div');
            answerElem.className = 'answer-element';
            answerElem.textContent = value;
            answerElem.dataset.elementId = name;

            // Offset each new element so they don't stack
            const elemCount = Object.keys(dropzoneMap).length;
            answerElem.style.left = (50 + elemCount * 80) + 'px';
            answerElem.style.top = (50 + elemCount * 30) + 'px';

            answerBox.appendChild(answerElem);
            dropzoneMap[name] = answerElem;


            // Attach drag handlers to answer element
            answerElem.onmousedown = (e) => {
              selectElement(dropzone); // Select the corresponding dropzone
              startAnswerDrag(e, answerElem);
            };
          }

          // DRAG ANSWER ELEMENT
          function startAnswerDrag(e, element) {
            isDragging = true;
            const rect = element.getBoundingClientRect();
            const parentRect = answerBox.getBoundingClientRect();

            dragOffsetX = e.clientX - rect.left;
            dragOffsetY = e.clientY - rect.top;

            document.onmousemove = (moveEvent) => {
              const newX = moveEvent.clientX - parentRect.left - dragOffsetX;
              const newY = moveEvent.clientY - parentRect.top - dragOffsetY;

              element.style.left = newX + 'px';
              element.style.top = newY + 'px';
            };

            document.onmouseup = () => {
              isDragging = false;
              document.onmousemove = null;
              document.onmouseup = null;
            };
          }

          // DELETE ELEMENT
          deleteBtn.onclick = () => {
            if (selectedElement) {
              const isDropzone = selectedElement.classList.contains('dropzone');
              const name = selectedElement.dataset.zoneName;
              if (isDropzone && dropzoneMap[name]) {
                dropzoneMap[name].remove();
                delete dropzoneMap[name];
              }


              selectedElement.remove();
              selectedElement = null;
              styleWidth.value = '';
              styleHeight.value = '';
              styleColor.value = '#ffffff';
              styleBorder.value = '#000000';
              styleThickness.value = '';
              dropzoneName.value = '';
              dropzoneValue.value = '';
              nameError.textContent = '';
              dropzoneName.classList.remove('error');
              dropzoneFields.classList.remove('show');
              valueFields.classList.remove('show');
            }
          };

          // HELPER: RGB TO HEX
          function rgbToHex(rgb) {
            if (!rgb || rgb === 'rgba(0, 0, 0, 0)') return '#ffffff';
            const match = rgb.match(/^rgba?\((\d+),\s*(\d+),\s*(\d+)/);
            if (!match) return '#ffffff';
            const hex = (x) => parseInt(x).toString(16).padStart(2, '0');
            return '#' + hex(match[1]) + hex(match[2]) + hex(match[3]);
          }
          // EXPORT CANVAS
          exportBtn.onclick = () => {
            const contentRow = document.querySelector('.content-row');
            const contentClone = contentRow.cloneNode(true);

            const img = contentClone.querySelector('img');
            if (img) {
              img.src = './' + uploadedImageName;
            }

            const wrapper = document.createElement('div');
            wrapper.style.display = 'flex';
            wrapper.style.gap = '18pc';
            wrapper.appendChild(contentClone);

            console.log(wrapper.outerHTML);
          };
        })
      </script>