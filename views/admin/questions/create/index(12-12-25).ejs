      <script type="text/template" id="matchquestionCardTemplate">
  <!-- Question Block -->
      <div class="card question-card mt-3">
        <div class="container">
          <div class="row">
            <div class="col-sm-12">
              <div class="form-group">
                <label>Question</label>
                <textarea name="array[][question]" class="form-control" rows="1"></textarea>
