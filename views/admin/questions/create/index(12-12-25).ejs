      <!-- First Instruction + Options Block -->
      <script type="text/template" id="matchInstructionCardTemplate">
  <div class="card question-card match-instruction-card mt-3">
    <div class="card-body">
      <div class="container">
        <div class="row">
          <div class="col-sm-12">
              <div class="col-sm-12">
                <div class="row">
