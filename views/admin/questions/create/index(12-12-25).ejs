<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Alata&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Fredoka+One&display=swap');

  :root {
    --bg-app: #1e1e1e;
    --bg-panel: #2c2c2c;
    --bg-hover: #383838;
    --bg-active: #0d99ff;
    --text-primary: #ffffff;
    --text-secondary: #b3b3b3;
    --border-color: #444444;
    --input-bg: #1e1e1e;
    --radius-sm: 4px;
    --radius-md: 6px;
  }

  /* LEFT TOOLBAR */
  .toolbar {
    width: 240px;
    background: var(--bg-panel);
    border-right: 1px solid #000;
    padding: 16px 8px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    box-sizing: border-box;
  }

  .toolbar-header {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-secondary);
    padding: 8px 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }

  .tool-btn {
    background: transparent;
    border: none;
    padding: 8px 12px;
    color: var(--text-primary) !important;
    border-radius: var(--radius-sm);
    text-align: left;
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: background 0.2s;
  }

  .tool-btn:hover {
    background: var(--bg-hover);
  }

  .tool-btn svg {
    opacity: 0.8;
  }

  /* MIDDLE TEMPLATE AREA */
  .canvas-wrapper {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .canvas {
    width: 80%;
    height: 100%;
    background: #c8ff80;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    padding: 20px;
    box-sizing: border-box;
  }

  .question-space {
    height: 80px;
    margin-bottom: 20px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    padding: 0 20px;
    box-sizing: border-box;
  }

  #editor_questionText {
    font-family: "Alata", sans-serif;
    font-size: 32px;
    color: #000000;
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    text-align: center;
  }

  #editor_questionText::placeholder {
    color: rgba(0, 0, 0, 0.3);
  }

  .content-row {
    flex: 1;
    display: flex;
    gap: 18pc;
  }

  .image-box {
    width: 40%;
    background: white;
    border-radius: 20px;
    position: relative;
    overflow: visible;
    box-shadow: rgba(0, 0, 0, 0.24) 0px 3px 8px;
    height: 80%;
  }

  .answer-box {
    flex: 1;
    border-radius: 10px;
    position: relative;
    overflow: visible;
  }

  /* DROPZONE STYLES */
  .dropzone {
    width: 80px;
    height: 40px;
    border: 2px solid #000;
    border-radius: 6px;
    background: #fff;
    position: absolute;
    cursor: grab;
    user-select: none;
    box-shadow: rgba(100, 100, 111, 0.2) 0px 7px 29px 0px;
  }

  .dropzone:active {
    cursor: grabbing;
  }

  /* LINE STYLES */
  .line {
    width: 80px;
    height: 2px;
    background: #000;
    position: absolute;
    cursor: grab;
    user-select: none;
  }

  .line:active {
    cursor: grabbing;
  }

  /* ANSWER ELEMENT STYLES */
  .answer-element {
    padding: 10px 15px;
    background: #8e583d;
    border-radius: 6px;
    position: absolute;
    cursor: grab;
    user-select: none;
    color: white;
    font-size: 20px;
    font-family: "Fredoka One", sans-serif;
  }

  .answer-element:active {
    cursor: grabbing;
  }

  /* RIGHT PROPERTIES PANEL */
  .properties {
    width: 280px;
    background: var(--bg-panel);
    border-left: 1px solid #000;
    padding: 0;
    box-sizing: border-box;
    color: var(--text-primary);
    overflow-y: auto;
    height: 77vh;
  }

  .prop-section {
    padding: 16px;
    border-bottom: 1px solid var(--border-color);
  }

  .prop-title {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .prop-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 12px;
  }

  .prop-field label {
    font-size: 14px;
    color: var(--text-secondary);
  }

  .prop-field input {
    background: var(--input-bg);
    border: 1px solid transparent;
    color: var(--text-primary);
    padding: 8px;
    border-radius: var(--radius-sm);
    font-size: 12px;
    font-family: "Inter", sans-serif;
    outline: none;
    transition: border-color 0.2s;
  }

  .prop-field input:focus {
    border-color: var(--bg-active);
    background: #222;
  }

  .prop-field input:hover {
    border-color: #555;
  }

  .prop-field input.error {
    border-color: #ff4d4d;
  }

  .error-message {
    font-size: 10px;
    color: #ff4d4d;
  }

  .delete-btn {
    background: transparent;
    border: 1px solid #ff4d4d;
    color: #ff4d4d;
    width: 100%;
    justify-content: center;
    margin-top: 10px;
  }

  .delete-btn:hover {
    background: rgba(255, 77, 77, 0.1);
  }

  .hidden-fields {
    display: none;
  }

  .hidden-fields.show {
    display: block;
  }



  /* identify editor */


  .top-navbar {
    height: 56px;
    background: linear-gradient(to bottom, #1a1a1a, #161616);
    border-bottom: 1px solid #2a2a2a;
    display: flex;
    align-items: center;
    padding: 0 24px;
    gap: 24px;
    box-sizing: border-box;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Inter", Helvetica, Arial, sans-serif;
  }

  .top-navbar-actions {
    display: flex;
    gap: 12px;
    margin-left: auto;
  }

  .top-navbar-actions div {
    padding: 8px 16px;
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    color: #fff;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 2px 8px rgba(99, 102, 241, 0.3);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Inter", Helvetica, Arial, sans-serif;
  }

  .top-navbar-actions div:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(99, 102, 241, 0.5);
  }

  .app-container {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  .sidebar-left {
    background: linear-gradient(to bottom, #1a1a1a, #151515);
    border-right: 1px solid #2a2a2a;
    display: flex;
    flex-direction: column;
    padding: 12px 0;
    overflow-y: auto;
  }

  .sidebar-left::-webkit-scrollbar {
    width: 8px;
  }

  .sidebar-left::-webkit-scrollbar-track {
    background: transparent;
  }

  .sidebar-left::-webkit-scrollbar-thumb {
    background: #404040;
    border-radius: 4px;
  }

  .sidebar-section {
    border-bottom: 1px solid #2a2a2a;
    padding: 16px 12px;
  }

  .sidebar-section:last-child {
    border-bottom: none;
  }

  .sidebar-section-title {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    color: #888;
    padding: 0 8px 12px;
    letter-spacing: 1px;
  }

  .toolbar {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    padding: 0 8px;
  }

  .toolbar div {
    padding: 10px;
    font-size: 12px;
    border-radius: 6px;
    border: 1px solid #333;
    cursor: pointer;
    background: #222;
    color: #e5e5e5;
    transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    user-select: none;
  }

  .toolbar div:hover {
    background: #2d2d2d;
    border-color: #404040;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
  }

  .toolbar div:active {
    transform: scale(0.98);
  }

  .properties-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .property-input-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .property-input-group label {
    font-size: 11px;
    color: #aaa;
    font-weight: 500;
  }

  .property-input-group input[type="number"],
  .property-input-group input[type="text"],
  .property-input-group input[type="color"] {
    padding: 8px;
    font-size: 12px;
    border-radius: 6px;
    border: 1px solid #333;
    background: #202020;
    color: #e5e5e5;
    transition: all 0.15s;
  }

  .property-input-group input:focus {
    outline: none;
    border-color: #6366f1;
    background: #252525;
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
  }

  .checkbox-row {
    margin-top: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: #ccc;
  }

  .checkbox-row input[type="checkbox"] {
    width: 16px;
    height: 16px;
    cursor: pointer;
    accent-color: #6366f1;
  }

  .no-selection {
    text-align: center;
    color: #666;
    font-size: 12px;
    padding: 20px;
  }

  .main-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .question-space-id {
    font-family: 'Alata', sans-serif;
    padding: 16px 40px;
    background: transparent;
    font-size: 20px;
    font-weight: 400;
    letter-spacing: 0.5px;
    position: absolute;
    flex-shrink: 0;
    z-index: 2;
    bottom: 34pc;
  }

  input#editor_questionText-id {
    border: none;
    font-size: 26px;
    background: #faf1bf;
    padding: 4px 19px;
    border-radius: 12px;
    text-align: center;
  }

  .canvas-wrapper-id {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: auto;
    padding: 40px;
    background: linear-gradient(135deg, #0f0f0f 0%, #1a1a1a 100%);
  }

  #canvas-id {
    width: 900px;
    height: 540px;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.6), 0 0 1px rgba(255, 255, 255, 0.1);
    position: relative;
    overflow: hidden;
    background-size: cover;
    background-position: center;
  }

  .canvas-item {
    position: absolute !important;
    border-radius: 4px;
    box-shadow: none;
    transition: box-shadow 0.15s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 10 !important;
  }

  .canvas-item.selected {
    box-shadow:
      0 0 0 2px #fff,
      0 0 0 3px #6366f1,
      0 4px 12px rgba(99, 102, 241, 0.3);
  }

  .canvas-item .content {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 4px;
    text-align: center;
  }

  .canvas-item .content.text {
    cursor: text;
    user-select: text;
  }

  .canvas-item .content img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .resize-handle {
    width: 8px;
    height: 8px;
    background: #6366f1;
    border-radius: 999px;
    position: absolute;
    right: -4px;
    bottom: -4px;
    cursor: se-resize;
    box-shadow: 0 0 0 2px #fff, 0 0 4px rgba(99, 102, 241, 0.5);
  }

  .dragging,
  .dragging * {
    user-select: none !important;
  }

  .action-link {
    padding: 8px 16px;
    background: #2d3748;
    border: none;
    border-radius: 6px;
    color: #f0f0f0;
    cursor: pointer;
    font-size: 12px;
    transition: background 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    margin-top: 8px;
    user-select: none;
    font-weight: 500;
  }

  .action-link:hover {
    background: #3a4556;
  }

  .action-link:active {
    transform: scale(0.98);
  }

  .delete-link {
    background: #c53030;
    grid-column: 1 / -1;
  }

  .delete-link:hover {
    background: #d63030;
  }

  .bg-button {
    grid-column: 1 / -1;
  }

  .forward-back-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 12px;
  }

  .forward-back-grid div {
    padding: 8px;
  }
</style>

<% if (typeof title !=='undefined' ) { %>
  <h1>
    <%= title %>
  </h1>
  <% } else { %>
    <h1>Fefdy</h1>
    <% } %>

      <div class="col-sm-12">
        <form id="questions_create_form" method="post" enctype="multipart/form-data" class="row">
          <div class="card">
            <div class="card-body">
              <div class="container">
                <div class="row">
                  <div class="col-sm-4">
                    <div class="form-group">
                      <label for="subject">Subject</label>
                      <select name="subject" id="subject" class="form-control">
                        <option value="">Select Subject</option>
                      </select>
                      <p class="validate_error text-danger" id="subject_error"></p>
                    </div>
                  </div>
                  <div class="col-sm-4">
                    <div class="form-group">
                      <label for="level">Level</label>
                      <select name="level" id="level" class="form-control">
                        <option value="">Select Level</option>
                      </select>
                      <p class="validate_error text-danger" id="level_error"></p>
                    </div>
                  </div>
                  <div class="col-sm-4">
                    <div class="form-group">
                      <label for="topic">Topic</label>
                      <select name="topic" id="topic" class="form-control">
                        <option value="">Select Topic</option>
                      </select>
                      <p class="validate_error text-danger" id="topic_error"></p>
                    </div>
                  </div>
                  <div class="col-sm-4">
                    <div class="form-group">
                      <label for="sub_topic">Sub Topic</label>
                      <select name="sub_topic" class="form-control" id="sub_topic">
                        <option value="">Select Sub Topic</option>
                      </select>
                      <p class="validate_error text-danger" id="sub_topic_error"></p>
                    </div>
                  </div>
                  <div class="col-sm-4">
                    <div class="form-group">
                      <label for="question_type">Question Type</label>
                      <select name="question_type" class="form-control" id="question_type">
                        <option value="">Select Question Type</option>
                      </select>
                      <p class="validate_error text-danger" id="question_type_error"></p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div id="questionCardContainer"></div>
        </form>
      </div>

