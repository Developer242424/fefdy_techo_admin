<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8">
  <title>Fefdy Report</title>
</head>

<body style="margin:0; padding:0; font-family:Segoe UI, Tahoma, Geneva, Verdana, sans-serif; background-color:#ffffff;">

  <table align="center" width="100%" cellpadding="0" cellspacing="0" border="0"
    style="border:1px solid #f0d2d2; margin:0 auto;">

    <!-- Header -->
    <tr>
      <td style="padding:20px;">
        <img src="cid:<%= logoCid %>" alt="Fefdy Logo" style="height:48px; display:inline-block; vertical-align:middle;">
      </td>
    </tr>

    <!-- Greeting Section -->
    <tr>
      <td style="background-color:#eef9e9; padding:24px; font-size:16px; line-height:1.5;">
       <p>Dear <strong><%= data.org_name %></strong>,</p>
       <p>Greetings from <i>Fefdy Brain Gym</i>!</p>
       
       <p>
         We are pleased to inform you that 
         <strong><%= data.ttl_students %> student<% if (data.ttl_students > 1) { %>s<% } %></strong>
         from your school have performed exceptionally well in the subjects and levels conducted by us.
       </p>
       
       <p>Below is a report on the students' performance statistics.</p>
      </td>
    </tr>

    <!-- Chart Section -->
    <tr>
      <td style="padding: 20px; border-top: 1px solid #ccc; border: 1px solid #ddd; padding: 10px; margin: 24px auto; max-width: 937px; box-shadow: rgba(0, 0, 0, 0.1) 0px 4px 12px; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    width: 700px;">
        <p style="color:#aaa; font-size:13px; margin:0;">Statistics</p>
        <h2 style="margin:5px 0 20px 0; font-size:20px;">Total summary of purchase</h2>

        <% 
          const getboughtlevels = data.getboughtlevels;
          const defaultColors = ["#3496AF", "#FCDEBE", "#96D74A", "#FFA07A", "#DA70D6"];
          const subjectColors = {};
          getboughtlevels.forEach((item, index) => {
            subjectColors[item.subject] = defaultColors[index % defaultColors.length];
          });
        %>

        <!-- Bar Chart Table -->
        <table cellpadding="0" cellspacing="0" width="100%" style="border-collapse:collapse; text-align:center;">
          <tr valign="bottom" style="height:160px;">

            <!-- Grade 1 -->
            <td>
              <% getboughtlevels.forEach(subject => {
                const height = Math.round((subject.bought_level / subject.ttl_level) * 100);
                const fnlHeight = height === 0 ? 1 : height;
              %>
                <div style="width:20px; height:<%= fnlHeight %>px; background:<%= subjectColors[subject.subject] %>; display:inline-block; margin-right:5px;"></div>
              <% }) %>
            </td>

          </tr>
        </table>

        <!-- Description below tabke -->
        <p style="font-size:14px; line-height:1.5; margin-top:20px;">
          This month, the school picked up <strong>LKG – Science</strong> with 3 levels.<br>
          For <strong>Grade 1</strong>, the school purchased <strong>Science and Math</strong>, each with 5 levels.<br>
          In <strong>Grade 2</strong>, the subjects <strong>Science and Math</strong> were also chosen, with 4 levels
          included for both.
        </p>

        <!-- Legend -->
        <p style="font-size:13px; margin-top:10px;">
          <!-- <span style="display:inline-block; width:12px; height:12px; background:#3496AF; border-radius:50%;"></span>
          Science &nbsp;&nbsp;
          <span style="display:inline-block; width:12px; height:12px; background:#FCDEBE; border-radius:50%;"></span>
          Maths &nbsp;&nbsp;
          <span style="display:inline-block; width:12px; height:12px; background:#96D74A; border-radius:50%;"></span>
          English -->
          <% getboughtlevels.forEach(subject => { %>
            <span style="display:inline-block; width:12px; height:12px; background:<%= subjectColors[subject.subject] %>; border-radius:50%;"></span>
            <%= subject.subject %> &nbsp;&nbsp;
          <% }) %>
        </p>
      </td>
    </tr>


    <!-- Performance Breakdown -->
    <tr>
      <td style="padding: 20px;">
        <h3 style="font-size: 18px; margin: 0 0 16px 0;">Performance Breakdown:</h3>

        <table width="100%" cellpadding="0" cellspacing="0">
          <!-- Legend -->
          <tr>
            <td colspan="2" style="padding: 20px;">
              <table cellpadding="6" cellspacing="0" style="font-family: Arial, sans-serif; font-size: 12px;">
                <tr>
                  <td style="width: 16px; height: 16px; border-radius: 16px; background-color: #C96868;"></td>
                  <td style="padding-left: 8px;">60% and above</td>
                  <td style="width: 16px; height: 16px;border-radius: 16px; background-color: #FADFA1;"></td>
                  <td style="padding-left: 8px;">40%–59%</td>
                  <td style="width: 16px; height: 16px;border-radius: 16px; background-color: #A79277;"></td>
                  <td style="padding-left: 8px;">Below 40%</td>
                  <td style="width: 16px; height: 16px;border-radius: 16px; background-color: #CCCCCC;"></td>
                  <td style="padding-left: 8px;">Not Attempted</td>
                </tr>
              </table>
            </td>
          </tr>

          <% const wholeData = data.data %>
          <% wholeData.forEach((value, index) => { %>
            <% if (index % 2 === 0) { %>
              <tr>
            <% } %>
          
            <td width="50%" valign="top" style="padding: 10px">
              <table width="100%" cellpadding="10" cellspacing="0" style="background: #edf7e3; border-radius: 12px;">
                <tr>
                  <td align="center" style="font-weight: bold; font-family: Arial, sans-serif;">
                    <%= value.standard %> - <%= value.students %> STUDENT<% if (value.students > 1) { %>S<% } %>
                  </td>
                </tr>

                <% const subData = value.data %>
                <% subData.forEach((sub_val, sub_ind) => { %>
                    <tr>
                        <td><%= sub_val.subject %>
                            <table width="100%" cellpadding="0" cellspacing="0" style="border-collapse: collapse;">
                              <tr style="border-radius:  16px;">
                                <!-- 60% and above -->
                                <td style="width: <%= sub_val.sixtyAbove_percent %>%; background-color: #C96868; height: 32px; color: #ffffff; font-size: 12px; text-align: center; font-family: Arial, sans-serif;">
                                  <% if (sub_val.sixtyAbove_percent > 0) { %>
                                    <%= sub_val.sixtyAbove_percent %>%
                                  <% } %>
                                </td>
                                
                                <!-- 40%–59% -->
                                <td style="width: <%= sub_val.fourtyAbove_percent %>%; background-color: #FADFA1; height: 32px; font-size: 12px; text-align: center; font-family: Arial, sans-serif;">
                                  <% if (sub_val.fourtyAbove_percent > 0) { %>
                                    <%= sub_val.fourtyAbove_percent %>%
                                  <% } %>
                                </td>
                                
                                <!-- Below 40% -->
                                <td style="width: <%= sub_val.fourtyBelow_percent %>%; background-color: #A79277; height: 32px; color: #ffffff; font-size: 12px; text-align: center; font-family: Arial, sans-serif;">
                                  <% if (sub_val.fourtyBelow_percent > 0) { %>
                                    <%= sub_val.fourtyBelow_percent %>%
                                  <% } %>
                                </td>
                                
                                <!-- Not Attempted -->
                                <td style="width: <%= sub_val.notAttended_percent %>%; background-color: #CCCCCC; height: 32px; color: #000000; font-size: 12px; text-align: center; font-family: Arial, sans-serif;">
                                  <% if (sub_val.notAttended_percent > 0) { %>
                                    <%= sub_val.notAttended_percent %>%
                                  <% } %>
                                </td>
                              </tr>
                            </table>
                        </td>
                    </tr>
                <% }) %>

              </table>
            </td>
          
            <% if (index % 2 === 1 || index === data.length - 1) { %>
              </tr>
            <% } %>
          <% }); %>

        </table>
      </td>
    </tr>

    <!-- Footer -->
    <tr>
      <td style="text-align: center; padding: 40px 20px 20px; color: #222; font-size: 14px; line-height: 1.6;">
        <p>Thank you for your continued support and active participation.<br>
          We look forward to welcoming even more enthusiastic participants in the future!</p>
        <p style="margin-top: 30px; font-size: 13px; color: #333;">
          Copyright © 2022. All Rights Reserved.<br>
          <span style="font-weight: bold;">Fefdy BrainGym Team</span>
        </p>
      </td>
    </tr>

  </table>
</body>

</html>