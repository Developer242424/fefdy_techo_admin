<body data-pc-preset="preset-1" data-pc-direction="ltr" data-pc-theme="light">
    <div class="loader-bg">
        <div class="loader-track">
            <div class="loader-fill"></div>
        </div>
    </div>
    <%- include('./layouts/sidebar.ejs') %>
        <%- include('./layouts/header.ejs') %>

            <div class="pc-container">
                <div class="pc-content">
                    <div class="page-header">
                        <div class="page-block">
                            <div class="row align-items-center">
                                <div class="col-md-12">
                                    <div class="page-header-title">
                                        <h5 class="m-b-10">Home</h5>
                                    </div>
                                    <ul class="breadcrumb">
                                        <li class="breadcrumb-item">
                                            <a href="<%= homeurl %>">Home</a>
                                        </li>
                                        <li class="breadcrumb-item">
                                            <a href="<%= url %>">
                                                <%= title %>
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <%- include(content) %>
                    </div>
                </div>
            </div>

            <%- include('./layouts/footer.ejs') %>

                <script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.min.js"></script>
                <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>

                <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
                <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
                <script src="/js/custom.js"></script>
                <script src="/js/handler.js"></script>

                <% if(url==='/admin/dashboard' ){ %>
                    <script src="/assets/js/plugins/apexcharts.min.js"></script>
                    <script src="/assets/js/pages/dashboard-default.js"></script>
                            <script src="/js/dashboard.js"></script>
                    <% } %>
                        <% if(url==='/admin/subjects' ){ %>
                            <script src="/js/subject.js"></script>
                            <% } %>
                                <% if(url==='/admin/topics' ){ %>
                                    <script src="/js/topics.js"></script>
                                    <% } %>
                                        <% if(url==='/admin/levelslist' ){ %>
                                            <script src="/js/levelslist.js"></script>
                                            <% } %>
                                                <% if(url==='/admin/category' ){ %>
                                                    <script src="/js/category.js"></script>
                                                    <% } %>
                                                        <% if(url==='/admin/subtopic' ){ %>
                                                            <script src="/js/subtopic.js"></script>
                                                            <% } %>
                                                                <% if(url==='/admin/organisation' ){ %>
                                                                    <script src="/js/organisation.js"></script>
                                                                    <% } %>
                                                                        <% if(url==='/admin/users' ){ %>
                                                                            <script src="/js/loginusers.js"></script>
                                                                            <% } %>
                                                                                <% if(url==='/admin/bulk' ){ %>
                                                                                    <script
                                                                                        src="/js/exportandimport.js"></script>
                                                                                    <% } %>
                                                                                        <% if(url==='/admin/create-questions'
                                                                                            ||
                                                                                            url==='/admin/questions-list'
                                                                                            ){ %>
                                                                                            <script
                                                                                                src="/js/questions.js"></script>
                                                                                            <% } %>
                                                                                                <% if(url==='/admin/sent-report'
                                                                                                    ){ %>
                                                                                                    <script
                                                                                                        src="/js/sentreport.js"></script>
                                                                                                    <% } %>
                                                                                                        <% if(url==='/admin/questions-category'
                                                                                                            ){ %>
                                                                                                            <script
                                                                                                                src="/js/questiontype.js"></script>
                                                                                                            <% } %>

                                                                                                        <script
                                                                                                            src="/assets/js/plugins/popper.min.js"></script>
                                                                                                        <script
                                                                                                            src="https://d2cwebsolutions.in/easytable-1.0.0/easytable-1.0.0.js"></script>
                                                                                                        <script
                                                                                                            src="/assets/js/plugins/simplebar.min.js"></script>
                                                                                                        <script
                                                                                                            src="/assets/js/plugins/bootstrap.min.js"></script>
                                                                                                        <script
                                                                                                            src="/assets/js/fonts/custom-font.js"></script>
                                                                                                        <script
                                                                                                            src="/assets/js/pcoded.js"></script>
                                                                                                        <script
                                                                                                            src="/assets/js/plugins/feather.min.js"></script>


</body>

</html>